
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>URL Shortener</title>

  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="min-h-screen bg-slate-100">

  <div class="max-w-6xl mx-auto px-6 py-12">

    <!-- Header -->

    <div class="text-center mb-10">

      <h1 class="text-4xl font-bold text-slate-800">
        🔗 URL Shortener
      </h1>

      <p class="text-slate-500 mt-2">
        Paste a long URL and generate a short link instantly.
      </p>

    </div>


    <!-- Success Box -->

    <% if (locals.id) { %>

        <div><a  href="<%= `http://localhost:8001/` %>"
         
          class="text-blue-600 hover:underline break-all" class="btn">Back</a></div>

      <div class="mb-8 bg-green-50 border border-green-200 rounded-xl p-5">

        <h3 class="font-semibold text-green-700 mb-2">
          URL Generated Successfully 🎉
        </h3>

        <a
          href="<%= `http://localhost:8001/${id}` %>"
          target="_blank"
          class="text-blue-600 hover:underline break-all"
        >
          <%= `http://localhost:8001/${id}` %>
        </a>

      </div>

    <% } %>


    <!-- Form Card -->

    <div class="bg-white rounded-2xl shadow-md p-8 mb-10">

      <form
        action="/url"
        method="POST"
        class="flex flex-col md:flex-row gap-4"
      >

        <input
          type="text"
          name="url"
          placeholder="https://example.com"
          required

          class="flex-1 border border-slate-300 rounded-lg px-4 py-3 outline-none focus:ring-2 focus:ring-blue-500"
        >

        <button
          type="submit"

          class="bg-blue-600 text-white px-8 py-3 rounded-lg hover:bg-blue-700 transition"
        >
          Generate
        </button>

      </form>

    </div>


    <!-- Table -->

    <% if (locals.urls && urls.length) { %>

      <div class="bg-white rounded-2xl shadow-md overflow-hidden">

        <div class="p-6 border-b">

          <h2 class="text-xl font-semibold">
            Generated URLs
          </h2>

        </div>

        <div class="overflow-x-auto">

          <table class="w-full">

            <thead class="bg-slate-50">

              <tr>

                <th class="text-left p-4">#</th>

                <th class="text-left p-4">Short ID</th>

                <th class="text-left p-4">Short URL</th>

                <th class="text-left p-4">Original URL</th>

                <th class="text-left p-4">Clicks</th>

              </tr>

            </thead>

            <tbody>

              <% urls.forEach((item,index)=>{ %>

                <tr class="border-t hover:bg-slate-50">

                  <td class="p-4">
                    <%= index+1 %>
                  </td>

                  <td class="p-4 font-semibold">
                    <%= item.shortId %>
                  </td>

                  <td class="p-4">

                    <a

                      href="<%= `http://localhost:8001/${item.shortId}` %>"

                      target="_blank"

                      class="text-blue-600 hover:underline"

                    >

                      Visit

                    </a>

                  </td>

                  <td class="p-4 max-w-xs truncate">

                    <%= item.redirectURL %>

                  </td>

                  <td class="p-4">

                    <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm">

                      <%= item.visitHistory.length %>

                    </span>

                  </td>

                </tr>

              <% }) %>

            </tbody>

          </table>

        </div>

      </div>

    <% } %>

  </div>

</body>

</html>

